# ──────────────────────────────────────────────────────────────────────────────
# .env.example — app workspace
#
# Template pour toutes les variables requises par ce workspace Terraform.
#
# Usage :
#   cp .env.example .env
#   # remplis les valeurs dans .env
#   source .env
#   terraform init
#   terraform plan
#   terraform apply
#
# NEVER committe .env — il est listé dans .gitignore.
# En CI/CD, injecte ces valeurs via les secrets du pipeline.
# ──────────────────────────────────────────────────────────────────────────────

# ── Connexion au cluster OpenShift ────────────────────────────────────────────
#
# Option A (recommandée en équipe) : remote state
#   Laisse cluster_url vide et configure les variables cluster_state_* ci-dessous.
#   Le workspace lira cluster_master_url depuis le state du workspace cluster/.
#
# Option B (dev local rapide) :
#   Remplis TF_VAR_cluster_url directement.
#   Obtenir l'URL : oc whoami --show-server
#   ⚠️  Sur ROKS le port NodePort peut changer après un update/redémarrage du master.
#   Pour le récupérer dynamiquement : export TF_VAR_cluster_url="$(oc whoami --show-server)"
TF_VAR_cluster_url=https://api.REPLACE_ME.example.com:6443

# Token du service account Terraform pour se connecter au cluster.
# Créer un SA dédié (recommandé, client oc >= 4.11) :
#   oc create serviceaccount terraform-sa -n kube-system
#   oc adm policy add-cluster-role-to-user cluster-admin -z terraform-sa -n kube-system
#   oc create token terraform-sa -n kube-system --duration=8760h
#
# Avec un client oc < 4.11 (ex: 4.10), utiliser un Secret de type token :
#   oc apply -f - <<EOF
#   apiVersion: v1
#   kind: Secret
#   metadata:
#     name: terraform-sa-token
#     namespace: kube-system
#     annotations:
#       kubernetes.io/service-account.name: terraform-sa
#   type: kubernetes.io/service-account-token
#   EOF
#   oc get secret terraform-sa-token -n kube-system -o jsonpath='{.data.token}' | base64 -d
#
# En dev local (expire ~24h) : export TF_VAR_cluster_token="$(oc whoami --show-token)"
TF_VAR_cluster_token=REPLACE_ME_WITH_SA_TOKEN

# Passer à true UNIQUEMENT en dev local avec certificat auto-signé.
TF_VAR_cluster_insecure=false

# ── Remote state (Option A — lire le cluster_master_url depuis le state) ─────
# Nécessite que le workspace cluster/ utilise un backend S3/COS partagé.
# TF_VAR_cluster_state_bucket=my-tfstate-bucket
# TF_VAR_cluster_state_key=payment-app/cluster/terraform.tfstate
# TF_VAR_cluster_state_region=eu-de
# TF_VAR_cluster_state_endpoint=https://s3.eu-de.cloud-object-storage.appdomain.cloud

# ── GitHub provider ────────────────────────────────────────────────────────────
# PAT GitHub avec le scope 'repo' pour gérer les Actions secrets.
# Générer sur : https://github.com/settings/tokens
TF_VAR_github_token=ghp_REPLACE_ME_WITH_GITHUB_PAT
TF_VAR_github_owner=REPLACE_ME_WITH_GITHUB_OWNER
TF_VAR_github_repository=REPLACE_ME_WITH_REPO_NAME

# ── Namespaces (optionnel — défauts fournis) ───────────────────────────────────
# TF_VAR_namespace_staging=bob-demo-staging
# TF_VAR_namespace_prod=bob-demo-prod

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Générer des mots de passe forts : openssl rand -base64 24
TF_VAR_postgres_password_staging=REPLACE_ME_WITH_STRONG_PASSWORD_STAGING
TF_VAR_postgres_password_prod=REPLACE_ME_WITH_STRONG_PASSWORD_PROD

# TF_VAR_postgres_image=postgres:15.6
# TF_VAR_postgres_db_staging=paymentdb_staging
# TF_VAR_postgres_db_prod=paymentdb_prod
# TF_VAR_postgres_user=paymentapp
# TF_VAR_postgres_pvc_size=5Gi
# TF_VAR_postgres_storage_class=

# ── Secrets GitHub Actions (valeurs injectées dans le pipeline CI/CD) ─────────
# TF_VAR_openshift_server : URL API → écrite dans le secret OPENSHIFT_SERVER
TF_VAR_openshift_server=https://api.REPLACE_ME.example.com:6443
# TF_VAR_openshift_token  : token CI (peut être différent du token Terraform)
TF_VAR_openshift_token=REPLACE_ME_WITH_CI_SA_TOKEN
# TF_VAR_openshift_registry : hostname du registre interne OpenShift
#   Obtenir avec : oc get route default-route -n openshift-image-registry --template='{{ .spec.host }}'
TF_VAR_openshift_registry=default-route-openshift-image-registry.apps.REPLACE_ME.example.com
