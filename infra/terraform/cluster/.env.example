# ──────────────────────────────────────────────────────────────────────────────
# .env.example — cluster workspace
#
# Template for all TF_VAR_* environment variables required by this workspace.
#
# Usage:
#   cp .env.example .env
#   # fill in the values marked REPLACE_ME
#   source .env
#   terraform init
#   terraform plan -out=tfplan
#   terraform apply tfplan
#
# NEVER commit .env to version control — it contains secrets.
# In CI/CD pipelines, inject these values as encrypted pipeline secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── IBM Cloud authentication ───────────────────────────────────────────────────
#
# IAM API key with the following minimum IAM access:
#   • Editor + Manager on the target resource group
#   • Editor on VPC Infrastructure Services
#   • Editor on Kubernetes Service
#   • Writer on IBM Cloud Object Storage (for registry COS bucket)
#
# Create at: https://cloud.ibm.com/iam/apikeys
TF_VAR_ibmcloud_api_key=REPLACE_ME_WITH_IBM_CLOUD_API_KEY

# ── Naming prefix ──────────────────────────────────────────────────────────────
#
# Short prefix prepended to all IBM Cloud resource names.
# Must be 3–12 lowercase alphanumeric/hyphen chars, starting with a letter.
# Default: payment
# TF_VAR_prefix=payment

# ── IBM Cloud region ───────────────────────────────────────────────────────────
#
# Multi-zone region where the VPC and cluster are created.
# Valid values: us-south, us-east, eu-de, eu-gb, jp-tok, jp-osa, au-syd, ca-tor, br-sao
# Default: eu-de
# TF_VAR_region=eu-de

# ── Resource group ─────────────────────────────────────────────────────────────
#
# Name of the IBM Cloud resource group.
# Find existing groups at: https://cloud.ibm.com/account/resource-groups
# Default: Default
# TF_VAR_resource_group=Default

# ── OpenShift version ──────────────────────────────────────────────────────────
#
# OpenShift version — major.minor only, e.g. "4.17" (module adds "_openshift" internally).
# List available versions with: ibmcloud ks versions --show-version openshift
# Default: 4.17
# TF_VAR_ocp_version=4.17

# ── Worker node machine type ───────────────────────────────────────────────────
#
# VPC Gen2 machine type (flavor).
# IaCArchitecture.md spec: 4 vCPU / 16 GB RAM → bx2.4x16
# List flavors: ibmcloud ks flavors --zone <region>-1 --provider vpc-gen2
# Default: bx2.4x16
# TF_VAR_worker_machine_type=bx2.4x16

# ── Workers per zone ───────────────────────────────────────────────────────────
#
# Number of worker nodes per zone.
# Architecture spec: 3 nodes total across 3 zones → 1 per zone.
# Default: 1
# TF_VAR_workers_per_zone=1

# ── Worker OS ─────────────────────────────────────────────────────────────────
#
# Operating system for worker nodes.
# Valid values for OCP 4.17: REDHAT_8_64, RHEL_9_64, RHCOS
# Default: REDHAT_8_64
# TF_VAR_worker_os=REDHAT_8_64

# ── VPC networking ─────────────────────────────────────────────────────────────
#
# VPC address space and subnet CIDRs.
# Defaults carve 10.240.0.0/18 into three /22 subnets (1022 addresses each).
# Only override if these CIDRs conflict with existing VPCs in your account.
# TF_VAR_vpc_cidr=10.240.0.0/18
# TF_VAR_subnet_cidrs='["10.240.0.0/22","10.240.4.0/22","10.240.8.0/22"]'

# ── Resource tags ──────────────────────────────────────────────────────────────
#
# Tags applied to all IBM Cloud resources for cost tracking.
# Default: ["project:payment-app","managed-by:terraform"]
# TF_VAR_resource_tags='["project:payment-app","managed-by:terraform","env:demo"]'
