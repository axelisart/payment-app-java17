# ──────────────────────────────────────────────────────────────────────────────
# .env.example
#
# Template for all TF_VAR_* environment variables required by this Terraform
# configuration. Copy this file to .env, fill in real values, and source it
# before running any Terraform commands:
#
#   cp .env.example .env
#   # edit .env with your real values
#   source .env
#   terraform init
#   terraform plan
#   terraform apply
#
# NEVER commit .env to version control. It is listed in .gitignore.
# In CI/CD pipelines, inject these values as pipeline secrets (e.g. GitHub
# Actions encrypted secrets, HashiCorp Vault dynamic credentials, etc.).
# ──────────────────────────────────────────────────────────────────────────────

# ── OpenShift cluster connection ───────────────────────────────────────────────

# TF_VAR_cluster_url
#   OpenShift API server URL.
#   Obtain with: oc whoami --show-server
#   Example: https://api.my-cluster.example.com:6443
TF_VAR_cluster_url=https://api.REPLACE_ME.example.com:6443

# TF_VAR_cluster_token
#   Service account token for Terraform to authenticate with the cluster.
#   The SA must have cluster-admin or a custom ClusterRole that allows
#   creating Namespaces, ResourceQuotas, NetworkPolicies, Deployments,
#   Services, PVCs, ServiceAccounts, Roles, and RoleBindings.
#
#   Create a dedicated Terraform SA (recommended):
#     oc create serviceaccount terraform-sa -n kube-system
#     oc adm policy add-cluster-role-to-user cluster-admin \
#       -z terraform-sa -n kube-system
#     oc create token terraform-sa -n kube-system --duration=8760h
TF_VAR_cluster_token=REPLACE_ME_WITH_SA_TOKEN

# TF_VAR_cluster_insecure
#   Set to true ONLY for local development against clusters with self-signed
#   certificates. Must be false (the default) in CI and production.
TF_VAR_cluster_insecure=false

# ── GitHub provider ────────────────────────────────────────────────────────────

# TF_VAR_github_token
#   GitHub Personal Access Token (classic) with the following scopes:
#     - repo            (full repository access to manage secrets)
#   Generate at: https://github.com/settings/tokens
#   For organisations, also ensure the token has SSO-authorised access.
TF_VAR_github_token=ghp_REPLACE_ME_WITH_GITHUB_PAT

# TF_VAR_github_owner
#   GitHub organisation name or personal username that owns the repository.
#   Example: my-org  or  myusername
TF_VAR_github_owner=REPLACE_ME_WITH_GITHUB_OWNER

# TF_VAR_github_repository
#   GitHub repository name (without the owner prefix).
#   Example: openshift-roks  (not: my-org/openshift-roks)
TF_VAR_github_repository=REPLACE_ME_WITH_REPO_NAME

# ── Namespace names (optional — defaults match IaCArchitecture.md) ─────────────

# TF_VAR_namespace_staging
#   Kubernetes namespace for the staging environment.
#   Default: bob-demo-staging
# TF_VAR_namespace_staging=bob-demo-staging

# TF_VAR_namespace_prod
#   Kubernetes namespace for the production environment.
#   Default: bob-demo-prod
# TF_VAR_namespace_prod=bob-demo-prod

# ── PostgreSQL credentials ─────────────────────────────────────────────────────

# TF_VAR_postgres_password_staging
#   Password for the PostgreSQL superuser in the STAGING instance.
#   Use a strong randomly generated value — minimum 20 characters recommended.
#   Generate with: openssl rand -base64 24
TF_VAR_postgres_password_staging=REPLACE_ME_WITH_STRONG_PASSWORD_STAGING

# TF_VAR_postgres_password_prod
#   Password for the PostgreSQL superuser in the PRODUCTION instance.
#   Must be different from the staging password.
#   Generate with: openssl rand -base64 24
TF_VAR_postgres_password_prod=REPLACE_ME_WITH_STRONG_PASSWORD_PROD

# ── PostgreSQL configuration (optional — sensible defaults provided) ───────────

# TF_VAR_postgres_image
#   PostgreSQL container image tag. Pin to a specific minor version.
#   Default: postgres:15.6
# TF_VAR_postgres_image=postgres:15.6

# TF_VAR_postgres_db_staging
#   Database name for the staging PostgreSQL instance.
#   Default: paymentdb_staging
# TF_VAR_postgres_db_staging=paymentdb_staging

# TF_VAR_postgres_db_prod
#   Database name for the production PostgreSQL instance.
#   Default: paymentdb_prod
# TF_VAR_postgres_db_prod=paymentdb_prod

# TF_VAR_postgres_user
#   PostgreSQL username. Same username is used for both staging and prod
#   (credentials are separate — see passwords above).
#   Default: paymentapp
# TF_VAR_postgres_user=paymentapp

# TF_VAR_postgres_pvc_size
#   Storage size for each PostgreSQL PVC (staging and prod each get this).
#   Default: 5Gi
# TF_VAR_postgres_pvc_size=5Gi

# TF_VAR_postgres_storage_class
#   StorageClass for the PostgreSQL PVCs. Leave empty to use the cluster default.
#   On OpenShift / ROKS: ibmc-block-gold, gp3-csi, or equivalent.
# TF_VAR_postgres_storage_class=

# ── GitHub Actions secrets — values stored in GitHub ──────────────────────────
# These four variables are DIFFERENT from TF_VAR_cluster_url / TF_VAR_cluster_token
# above. They hold the values that get WRITTEN INTO GitHub Actions secrets and
# are then READ by the CI/CD pipeline at workflow runtime.
# In most setups they are the same values — but they are kept separate so you can
# use a restricted CI token with fewer permissions than the Terraform SA token.

# TF_VAR_openshift_server
#   OpenShift API server URL stored as the OPENSHIFT_SERVER Actions secret.
#   Used by `oc login` in the CI/CD workflow.
#   Same format as TF_VAR_cluster_url.
TF_VAR_openshift_server=https://api.REPLACE_ME.example.com:6443

# TF_VAR_openshift_token
#   Service account token stored as the OPENSHIFT_TOKEN Actions secret.
#   This can be a different (lower-privilege) SA than the Terraform SA — the CI
#   pipeline only needs permission to push images and `oc apply` the deployment.
#   Generate with: oc create token ci-sa -n bob-demo-staging --duration=8760h
TF_VAR_openshift_token=REPLACE_ME_WITH_CI_SA_TOKEN

# TF_VAR_openshift_registry
#   External hostname of the OpenShift internal image registry.
#   Required for `docker login` and `docker push` in the CI workflow.
#
#   Obtain with:
#     oc get route default-route \
#       -n openshift-image-registry \
#       --template='{{ .spec.host }}'
#
#   Typical value:
#     default-route-openshift-image-registry.apps.<cluster-domain>
TF_VAR_openshift_registry=default-route-openshift-image-registry.apps.REPLACE_ME.example.com

# ── ResourceQuota overrides (optional) ────────────────────────────────────────
# These are set to the values from IaCArchitecture.md by default.
# Override only if you need to adjust per-namespace resource budgets.

# TF_VAR_quota_staging_requests_cpu=4
# TF_VAR_quota_staging_limits_cpu=8
# TF_VAR_quota_staging_requests_memory=8Gi
# TF_VAR_quota_staging_limits_memory=16Gi

# TF_VAR_quota_prod_requests_cpu=4
# TF_VAR_quota_prod_limits_cpu=8
# TF_VAR_quota_prod_requests_memory=8Gi
# TF_VAR_quota_prod_limits_memory=16Gi
