{# ─────────────────────────────────────────────────────────────────────────────
   roles/payment-app/templates/postgres-credentials.yml.j2

   Kubernetes Secret template for PostgreSQL application credentials.

   Rendered by roles/payment-app/tasks/secret.yml using:
     lookup('template', 'postgres-credentials.yml.j2') | from_yaml

   The Secret is consumed by the payment-service Deployment via envFrom:
     envFrom:
       - secretRef:
           name: postgres-credentials

   Keys map directly to Spring Boot datasource properties via the
   Spring environment variable binding convention (UPPER_SNAKE_CASE):
     DB_URL      → spring.datasource.url
     DB_USER     → spring.datasource.username
     DB_PASSWORD → spring.datasource.password

   stringData is used (not data) — the kubernetes.core.k8s module sends
   stringData to the API server, which base64-encodes the values server-side.
   This avoids manual base64 encoding in the playbook and keeps the template
   readable.

   SECURITY: This file must never be committed with real credential values.
   Supply db_user and db_password via Ansible Vault or environment variables.
   The task that renders this template sets no_log: true.
───────────────────────────────────────────────────────────────────────────── #}
---
apiVersion: v1
kind: Secret
metadata:
  name: {{ postgres_secret_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/managed-by: ansible
    app.kubernetes.io/part-of: payment-app
    app.kubernetes.io/component: secret
    app.kubernetes.io/environment: {{ env_label }}
  annotations:
    app.kubernetes.io/description: "PostgreSQL credentials for payment-service (managed by Ansible)"
    # Record which playbook run last updated this Secret (without leaking values).
    ansible/last-applied-by: "payment-app role"
type: Opaque
stringData:
  # JDBC URL — in-namespace short DNS form. The payment-service connects to
  # postgres-service on port 5432 within the same namespace.
  # Full FQDN form (cross-namespace): jdbc:postgresql://postgres-service.{{ k8s_namespace }}.svc.cluster.local:5432/{{ postgres_db }}
  DB_URL: {{ db_url }}

  # PostgreSQL username.
  # Matches POSTGRES_USER env var set on the PostgreSQL Deployment by Terraform.
  DB_USER: {{ db_user }}

  # PostgreSQL password.
  # Matches POSTGRES_PASSWORD env var set on the PostgreSQL Deployment by Terraform.
  # PLACEHOLDER: replace via Ansible Vault (vault_db_password_{{ env_label }})
  DB_PASSWORD: {{ db_password }}
